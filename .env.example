# ═══════════════════════════════════════════
# Cafe Flow Premium — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env
# ═══════════════════════════════════════════

# ─── Database (SQL Server) ───────────────
DB_HOST=localhost
DB_PORT=1434
DB_USER=sa
DB_PASSWORD=your_strong_password_here
DB_NAME=cute_calendar

# ─── Authentication ───────────────────────
# Tạo chuỗi ngẫu nhiên dài ≥32 ký tự:
# openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_min_32_chars_here

# ─── CORS ─────────────────────────────────
# Để trống khi dev local. Khi deploy, điền domain Vercel:
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=

# ─── Frontend (Vite) ──────────────────────
# Đặt trong frontend/.env
# VITE_API_URL=http://localhost:8080
